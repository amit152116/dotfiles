#!/usr/bin/env bash
# TruffleHog GitHub Security Scanner
# Scan repositories for leaked secrets and credentials

set -euo pipefail

# --- Configuration ---
DEFAULT_GITHUB_USER="amit152116"
LOG_DIR="$HOME/trufflehog-reports"
MAX_REPOS_PER_PAGE=100
SCAN_TIMEOUT=300 # 5 minutes per repo

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color

# --- Logging Functions ---
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_scan() {
    echo -e "${CYAN}[SCAN]${NC} $1"
}

log_found() {
    echo -e "${MAGENTA}[FOUND]${NC} $1"
}

# --- Header ---
print_header() {
    echo "=========================================="
    echo " 🔐 TruffleHog Security Scanner"
    echo "=========================================="
}

# --- Dependency Checks ---
check_dependencies() {
    local missing=()

    # Check for trufflehog
    if ! command -v trufflehog &>/dev/null; then
        missing+=("trufflehog")
    fi

    # Check for jq (for GitHub API parsing)
    if ! command -v jq &>/dev/null; then
        missing+=("jq")
    fi

    # Check for curl
    if ! command -v curl &>/dev/null; then
        missing+=("curl")
    fi

    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing required dependencies: ${missing[*]}"
        echo ""
        log_info "Installation instructions:"

        for dep in "${missing[@]}"; do
            case "$dep" in
            trufflehog)
                echo "  TruffleHog:"
                echo "    brew install trufflehog  # macOS"
                echo "    # Or download from: https://github.com/trufflesecurity/trufflehog/releases"
                ;;
            jq)
                echo "  jq:"
                echo "    sudo apt install jq      # Debian/Ubuntu"
                echo "    brew install jq          # macOS"
                ;;
            curl)
                echo "  curl:"
                echo "    sudo apt install curl    # Debian/Ubuntu"
                echo "    brew install curl        # macOS"
                ;;
            esac
        done

        return 1
    fi

    return 0
}

# --- Directory Management ---
ensure_log_directory() {
    if [[ ! -d "$LOG_DIR" ]]; then
        mkdir -p "$LOG_DIR"
        log_success "Created log directory: $LOG_DIR"
    fi
}

# --- GitHub API Functions ---
fetch_github_repos() {
    local username="$1"
    local page=1
    local all_repos=()

    log_info "Fetching repositories for user: $username"

    while true; do
        local url="https://api.github.com/users/$username/repos?per_page=$MAX_REPOS_PER_PAGE&page=$page&sort=updated"

        # Fetch repos with error handling
        local response
        response=$(curl -s -w "\n%{http_code}" "$url")
        local http_code=$(echo "$response" | tail -n1)
        local body=$(echo "$response" | sed '$d')

        if [[ "$http_code" != "200" ]]; then
            if [[ "$http_code" == "404" ]]; then
                log_error "User '$username' not found on GitHub"
            else
                log_error "GitHub API error (HTTP $http_code)"
            fi
            return 1
        fi

        # Parse repos
        local repos
        repos=$(echo "$body" | jq -r '.[].clone_url' 2>/dev/null)

        if [[ -z "$repos" ]]; then
            break
        fi

        while IFS= read -r repo; do
            [[ -n "$repo" ]] && all_repos+=("$repo")
        done <<<"$repos"

        # Check if we got a full page
        local count
        count=$(echo "$body" | jq -r 'length' 2>/dev/null)
        if [[ "$count" -lt "$MAX_REPOS_PER_PAGE" ]]; then
            break
        fi

        ((page++))
    done

    if [[ ${#all_repos[@]} -eq 0 ]]; then
        log_warning "No repositories found for user: $username"
        return 1
    fi

    log_success "Found ${#all_repos[@]} repositories"
    printf '%s\n' "${all_repos[@]}"
}

# --- Scanning Functions ---
scan_repository() {
    local repo_url="$1"
    local output_file="$2"
    local repo_name
    repo_name=$(basename "$repo_url" .git)

    log_scan "Scanning: $repo_name"
    log_info "URL: $repo_url"

    # Run trufflehog with timeout
    local start_time=$(date +%s)

    if timeout "$SCAN_TIMEOUT" trufflehog git "$repo_url" --no-update --json >"$output_file" 2>/dev/null; then
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))

        # Count findings
        local findings=0
        if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
            findings=$(jq -s 'length' "$output_file" 2>/dev/null || echo "0")
        fi

        if [[ "$findings" -gt 0 ]]; then
            log_found "⚠️  Found $findings potential secret(s) in $repo_name (${duration}s)"
        else
            log_success "✓ No secrets found in $repo_name (${duration}s)"
        fi

        return 0
    else
        log_error "Scan failed or timed out for $repo_name"
        return 1
    fi
}

scan_all_github_repos() {
    local username="$1"

    print_header
    echo " Mode: Scan All GitHub Repositories"
    echo "=========================================="
    echo ""

    # Fetch repositories
    local repos
    if ! repos=$(fetch_github_repos "$username"); then
        return 1
    fi

    # Create session directory
    local session_dir="$LOG_DIR/github-$username-$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$session_dir"
    log_info "Reports will be saved to: $session_dir"
    echo ""

    # Scan each repository
    local count=0
    local total
    total=$(echo "$repos" | wc -l)
    local failed=0
    local secrets_found=0

    while IFS= read -r repo_url; do
        [[ -z "$repo_url" ]] && continue

        ((count++))
        local repo_name
        repo_name=$(basename "$repo_url" .git)

        echo -e "${CYAN}[$count/$total]${NC} Processing: $repo_name"

        local output_file="$session_dir/${repo_name}.json"

        if scan_repository "$repo_url" "$output_file"; then
            # Count secrets
            if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
                local findings
                findings=$(jq -s 'length' "$output_file" 2>/dev/null || echo "0")
                if [[ "$findings" -gt 0 ]]; then
                    ((secrets_found += findings))
                fi
            fi
        else
            ((failed++))
        fi

        echo ""
    done <<<"$repos"

    # Summary
    echo "=========================================="
    echo " Scan Summary"
    echo "=========================================="
    log_info "Total repositories scanned: $count"

    if [[ "$secrets_found" -gt 0 ]]; then
        log_warning "Total secrets found: $secrets_found"
    else
        log_success "No secrets found across all repositories"
    fi

    if [[ "$failed" -gt 0 ]]; then
        log_warning "Failed scans: $failed"
    fi

    log_info "Reports saved in: $session_dir"
    echo "=========================================="

    # Offer to view results
    if [[ "$secrets_found" -gt 0 ]]; then
        echo ""
        echo -n "View detailed results? [y/N]: "
        read -r view_choice

        if [[ "$view_choice" =~ ^[Yy]$ ]]; then
            generate_summary_report "$session_dir"
        fi
    fi
}

scan_local_repository() {
    local repo_path="${1:-$PWD}"

    print_header
    echo " Mode: Scan Local Repository"
    echo "=========================================="
    echo ""

    # Validate it's a git repo
    if [[ ! -d "$repo_path/.git" ]]; then
        log_error "Not a git repository: $repo_path"
        log_info "Please run from inside a git repository or specify a valid path"
        return 1
    fi

    local repo_name
    repo_name=$(basename "$repo_path")

    log_info "Repository: $repo_name"
    log_info "Path: $repo_path"
    echo ""

    # Create output file
    local output_file="$LOG_DIR/${repo_name}-$(date +%Y%m%d-%H%M%S).json"

    # Scan
    log_scan "Scanning local repository..."

    if scan_repository "$repo_path" "$output_file"; then
        # Check for findings
        local findings=0
        if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
            findings=$(jq -s 'length' "$output_file" 2>/dev/null || echo "0")
        fi

        echo ""
        echo "=========================================="
        echo " Scan Complete"
        echo "=========================================="

        if [[ "$findings" -gt 0 ]]; then
            log_warning "Found $findings potential secret(s)"
            log_info "Report: $output_file"

            echo ""
            echo -n "View findings? [y/N]: "
            read -r view_choice

            if [[ "$view_choice" =~ ^[Yy]$ ]]; then
                view_scan_results "$output_file"
            fi
        else
            log_success "No secrets found!"
            log_info "Report: $output_file"
        fi

        echo "=========================================="
    else
        return 1
    fi
}

scan_single_github_repo() {
    local repo_url="$1"

    print_header
    echo " Mode: Scan Single GitHub Repository"
    echo "=========================================="
    echo ""

    local repo_name
    repo_name=$(basename "$repo_url" .git)

    # Create output file
    local output_file="$LOG_DIR/${repo_name}-$(date +%Y%m%d-%H%M%S).json"

    if scan_repository "$repo_url" "$output_file"; then
        # Check for findings
        local findings=0
        if [[ -f "$output_file" ]] && [[ -s "$output_file" ]]; then
            findings=$(jq -s 'length' "$output_file" 2>/dev/null || echo "0")
        fi

        echo ""
        echo "=========================================="
        echo " Scan Complete"
        echo "=========================================="

        if [[ "$findings" -gt 0 ]]; then
            log_warning "Found $findings potential secret(s)"
            log_info "Report: $output_file"

            echo ""
            echo -n "View findings? [y/N]: "
            read -r view_choice

            if [[ "$view_choice" =~ ^[Yy]$ ]]; then
                view_scan_results "$output_file"
            fi
        else
            log_success "No secrets found!"
            log_info "Report: $output_file"
        fi

        echo "=========================================="
    fi
}

# --- Result Viewing ---
view_scan_results() {
    local json_file="$1"

    if [[ ! -f "$json_file" ]]; then
        log_error "Result file not found: $json_file"
        return 1
    fi

    echo ""
    echo "=========================================="
    echo " Detected Secrets"
    echo "=========================================="

    # Parse and display findings
    jq -r '.[] | "
\(.DetectorName // "Unknown")
  File: \(.SourceMetadata.Data.Git.file // "N/A")
  Line: \(.SourceMetadata.Data.Git.line // "N/A")
  Commit: \(.SourceMetadata.Data.Git.commit // "N/A")
  "' "$json_file" 2>/dev/null || {
        log_error "Failed to parse results"
        log_info "Raw file available at: $json_file"
    }
}

generate_summary_report() {
    local session_dir="$1"

    echo ""
    echo "=========================================="
    echo " Detailed Findings Report"
    echo "=========================================="

    local total_secrets=0
    local repos_with_secrets=0

    for json_file in "$session_dir"/*.json; do
        [[ ! -f "$json_file" ]] && continue

        local findings
        findings=$(jq -s 'length' "$json_file" 2>/dev/null || echo "0")

        if [[ "$findings" -gt 0 ]]; then
            ((repos_with_secrets++))
            ((total_secrets += findings))

            local repo_name
            repo_name=$(basename "$json_file" .json)

            echo ""
            echo -e "${YELLOW}Repository: $repo_name${NC}"
            echo -e "${RED}Secrets found: $findings${NC}"

            # Show first few findings
            jq -r '.[] | "  • \(.DetectorName // "Unknown") in \(.SourceMetadata.Data.Git.file // "N/A")"' "$json_file" 2>/dev/null | head -n 5

            if [[ "$findings" -gt 5 ]]; then
                echo "  ... and $((findings - 5)) more"
            fi
        fi
    done

    echo ""
    echo "=========================================="
    log_warning "Total secrets across $repos_with_secrets repositories: $total_secrets"
    echo "=========================================="
}

# --- Interactive Menu ---
show_menu() {
    print_header

    echo ""
    echo "Select operation:"
    echo "  1) Scan current local repository"
    echo "  2) Scan specific local repository"
    echo "  3) Scan all GitHub repos for a user"
    echo "  4) Scan single GitHub repository"
    echo "  5) View previous scan results"
    echo "  6) Exit"
    echo ""
}

interactive_menu() {
    while true; do
        show_menu
        echo -n "Enter choice [1-6]: "
        read -r choice
        echo ""

        case $choice in
        1)
            scan_local_repository "$PWD"
            break
            ;;
        2)
            echo -n "Enter repository path: "
            read -r repo_path
            scan_local_repository "$repo_path"
            break
            ;;
        3)
            echo -n "Enter GitHub username [$DEFAULT_GITHUB_USER]: "
            read -r username
            username="${username:-$DEFAULT_GITHUB_USER}"
            scan_all_github_repos "$username"
            break
            ;;
        4)
            echo -n "Enter GitHub repository URL: "
            read -r repo_url
            scan_single_github_repo "$repo_url"
            break
            ;;
        5)
            list_previous_scans
            ;;
        6)
            log_info "Exiting..."
            exit 0
            ;;
        *)
            log_error "Invalid choice. Please select 1-6."
            sleep 1
            ;;
        esac
    done
}

list_previous_scans() {
    echo "=========================================="
    echo " Previous Scan Results"
    echo "=========================================="

    if [[ ! -d "$LOG_DIR" ]] || [[ -z "$(ls -A "$LOG_DIR" 2>/dev/null)" ]]; then
        log_warning "No previous scans found"
        echo "=========================================="
        return
    fi

    # List recent scans
    local count=0
    while IFS= read -r file; do
        ((count++))
        local filename=$(basename "$file")
        local size=$(du -h "$file" | cut -f1)
        local findings
        findings=$(jq -s 'length' "$file" 2>/dev/null || echo "0")

        echo "$count) $filename ($size) - $findings findings"
    done < <(find "$LOG_DIR" -name "*.json" -type f -mtime -30 | sort -r | head -n 10)

    if [[ "$count" -eq 0 ]]; then
        log_warning "No recent scan results found"
    else
        echo ""
        echo -n "View a scan? [1-$count or N]: "
        read -r view_choice

        if [[ "$view_choice" =~ ^[0-9]+$ ]] && [[ "$view_choice" -ge 1 ]] && [[ "$view_choice" -le "$count" ]]; then
            local selected_file
            selected_file=$(find "$LOG_DIR" -name "*.json" -type f -mtime -30 | sort -r | head -n "$view_choice" | tail -n 1)
            view_scan_results "$selected_file"
        fi
    fi

    echo "=========================================="
}

# --- Usage ---
usage() {
    cat <<EOF
Usage: $0 [COMMAND] [OPTIONS]

Commands:
  local [PATH]         Scan local repository (default: current directory)
  github-all [USER]    Scan all GitHub repos for user (default: $DEFAULT_GITHUB_USER)
  github-one <URL>     Scan single GitHub repository
  results              View previous scan results
  (no command)         Interactive menu

Options:
  --user <username>    GitHub username (for github-all)
  --help               Show this help message

Examples:
  $0                                    # Interactive menu
  $0 local                              # Scan current repo
  $0 local /path/to/repo                # Scan specific repo
  $0 github-all                         # Scan all repos for default user
  $0 github-all --user johndoe          # Scan all repos for johndoe
  $0 github-one https://github.com/user/repo.git
  $0 results                            # View previous scans

Reports are saved to: $LOG_DIR
EOF
    exit 0
}

# --- Main ---
main() {
    # Check dependencies first
    if ! check_dependencies; then
        exit 1
    fi

    # Ensure log directory exists
    ensure_log_directory

    local cmd="${1:-}"

    # Interactive mode if no arguments
    if [[ -z "$cmd" ]]; then
        interactive_menu
        return 0
    fi

    # Command-line mode
    case "$cmd" in
    local)
        scan_local_repository "${2:-$PWD}"
        ;;
    github-all)
        local username="$DEFAULT_GITHUB_USER"

        # Parse options
        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
            --user)
                username="${2:-$DEFAULT_GITHUB_USER}"
                shift 2
                ;;
            *)
                username="$1"
                shift
                ;;
            esac
        done

        scan_all_github_repos "$username"
        ;;
    github-one)
        if [[ -z "${2:-}" ]]; then
            log_error "Repository URL required"
            log_info "Example: $0 github-one https://github.com/user/repo.git"
            exit 1
        fi
        scan_single_github_repo "$2"
        ;;
    results)
        list_previous_scans
        ;;
    -h | --help | help)
        usage
        ;;
    *)
        log_error "Unknown command: $cmd"
        usage
        ;;
    esac
}

# Run main
main "$@"
